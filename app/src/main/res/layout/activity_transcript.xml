<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="‹"
            android:textSize="26sp"
            android:textColor="#AAAAAA"
            android:background="@android:color/transparent"
            android:padding="0dp"
            android:textAllCaps="false"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <!-- Tappable title — tap to rename -->
            <TextView
                android:id="@+id/fileNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transcript"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:clickable="true"
                android:focusable="true"
                android:drawableEnd="@drawable/ic_edit_small"
                android:drawablePadding="6dp"/>

            <TextView
                android:id="@+id/fileDateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jun 10, 2025 · 14:32"
                android:textColor="#555555"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/shareButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Share"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_share"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>

    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#111111"/>

    <!-- Word count bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/wordCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— words"
            android:textColor="#333333"
            android:textSize="12sp"
            android:fontFamily="monospace"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/charCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— chars"
            android:textColor="#333333"
            android:textSize="12sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0F0F0F"/>

    <!-- Scrollable editable transcript body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadeScrollbars="true">

        <!-- Changed to EditText so user can tap and type -->
        <EditText
            android:id="@+id/transcriptContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="48dp"
            android:textColor="#DDDDDD"
            android:textSize="17sp"
            android:lineSpacingMultiplier="1.6"
            android:letterSpacing="0.01"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine|textCapSentences"
            android:gravity="top|start"
            android:hint="Start typing..."
            android:textColorHint="#333333"/>

    </ScrollView>

</LinearLayout>